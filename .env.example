# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/uniq_auto

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Scraper
SCRAPE_INTERVAL_MINUTES=15
MIN_OPPORTUNITY_SCORE=60
HEADLESS=true
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0

# Fiyat filtreleri (TL)
SEGMENT_ORTA_MIN=500000
SEGMENT_ORTA_MAX=1500000
SEGMENT_PREMIUM_MIN=1500000
SEGMENT_PREMIUM_MAX=3000000
